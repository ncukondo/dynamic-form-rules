  "version": "2.0.0",
  "tasks": [
    {
      "type": "deno",
      "command": "run",
      "args": [
        "-A",
        "${file}"
      ],
      "problemMatcher": [
        "$deno"
      ],
      "label": "deno:run"
    },
    {
      "type": "deno",
      "command": "test",
      "args": [
        "-A",
        "${file}"
      ],
      "problemMatcher": [
        "$deno"
      ],
      "label": "deno:test"
    },
    {
      "type": "deno",
      "command": "run",
      "args": [
        "-A",
        "https://github.com/ncukondo/deno-to-gas/raw/main/cli.ts",
        "${file}"
      ],
      "problemMatcher": [
        "$deno"
      ],
      "label": "deno:convert-to-gas"
    }
  ]
}